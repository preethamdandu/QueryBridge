NODE_ENV=development
PORT=4000

# Infrastructure
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/querybridge
REDIS_URL=redis://localhost:6379
REDIS_ENV_PREFIX=development

# MCP transport
# Use "stub" for local placeholder mode or "http" for real service calls
MCP_TRANSPORT_MODE=stub
QUERY_SERVICE_URL=http://localhost:4001
AUTH_SERVICE_URL=http://localhost:4002
LLM_ROUTER_SERVICE_URL=http://localhost:4003
ANALYTICS_SERVICE_URL=http://localhost:4004

# JWT
JWT_PUBLIC_KEY=replace-with-public-key

# LLM provider routing (router service)
LLM_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=
